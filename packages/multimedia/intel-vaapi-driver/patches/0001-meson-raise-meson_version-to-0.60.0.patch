From 37e2fdb8079e810c8fa53df15a24db8ae3df671c Mon Sep 17 00:00:00 2001
From: Rudi Heitbaum <rudi@heitbaum.com>
Date: Thu, 2 Jul 2026 21:12:50 +1000
Subject: [PATCH 1/3] meson: raise meson_version to 0.60.0

The build uses the fallback argument to dependency() (added in 0.54.0)
and the deprecated argument to option() (added in 0.60.0), but declares
a minimum of 0.43.0, which meson warns about. Declare the minimum that
actually matches the features in use.
---
 meson.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/meson.build b/meson.build
index 95e13bce..25171ac9 100644
--- a/meson.build
+++ b/meson.build
@@ -1,7 +1,7 @@
 project(
   'intel-vaapi-driver', 'c',
   version : '2.4.5.0',
-  meson_version : '>= 0.43.0',
+  meson_version : '>= 0.60.0',
   default_options : [ 'warning_level=1',
                       'buildtype=debugoptimized' ])
 
-- 
2.47.1.windows.2

